mqtt_sub.py
import paho.mqtt.client as mqtt

BROKER = "localhost"
PORT = 8883
TOPIC = "iot/test"

def on_message(client, userdata, msg):
    print(f"Received: {msg.payload.decode()}")

client = mqtt.Client()
client.tls_set(ca_certs="ca.crt")

client.connect(BROKER, PORT)
client.subscribe(TOPIC)
client.on_message = on_message

print("Subscriber running...")
client.loop_forever()



mqtt_anomaly_pub.py

import paho.mqtt.client as mqtt
import time

BROKER = "localhost"
PORT = 8883
TOPIC = "iot/test"

client = mqtt.Client()
client.tls_set(ca_certs="ca.crt")

client.connect(BROKER, PORT)

print("Sending abnormal burst traffic...")

# Flooding: 100 rapid messages
for i in range(100):
    message = f"Attack message {i}"
    client.publish(TOPIC, message)
    time.sleep(0.01)  # very small delay → burst traffic

print("Flooding completed.")
client.disconnect()
