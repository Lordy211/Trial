Step 7: Feature Extraction & Anomaly Detection
Create anomaly_detection.py:
Python
import pandas as pd
import numpy as np

# Load timestamps
df = pd.read_csv("timestamps.csv")

# Calculate inter-arrival time
df['diff'] = df['timestamp'].diff()

# Drop NaN
df = df.dropna()

# Compute statistics
mean = df['diff'].mean()
std = df['diff'].std()

# Three-Sigma Rule
upper = mean + 3*std
lower = mean - 3*std

print(f"Mean: {mean}")
print(f"Std Dev: {std}")
print(f"Upper Limit: {upper}")
print(f"Lower Limit: {lower}")

# Detect anomalies
df['anomaly'] = (df['diff'] > upper) | (df['diff'] < lower)

print("\nAnomalies detected:")
print(df[df['anomaly']])
