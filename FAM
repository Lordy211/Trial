Step 5: Subscriber + Data Logger

Create subscriber_logger.py:
Python
import paho.mqtt.client as mqtt
import time
import csv

timestamps = []

def on_message(client, userdata, msg):
    t = time.time()
    timestamps.append(t)
    print("Received:", msg.payload.decode())

client = mqtt.Client()
client.connect("localhost", 1883)
client.subscribe("iot/sensor")
client.on_message = on_message

print("Logging data...")
client.loop_start()

# Collect data for 30 seconds
time.sleep(30)
client.loop_stop()

# Save timestamps
with open("timestamps.csv", "w", newline="") as f:
    writer = csv.writer(f)
    writer.writerow(["timestamp"])
    for t in timestamps:
        writer.writerow([t])

