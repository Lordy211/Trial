from scipy.stats import entropy

def entropy_test(puf):
    responses = [get_response(puf, generate_challenge()) for _ in range(200)]
    p0 = responses.count(0)/len(responses)
    p1 = responses.count(1)/len(responses)
    
    return entropy([p0, p1], base=2)

entropy_scores = [entropy_test(p) for p in pufs]
print("Entropy:", entropy_scores[:5])

# Enroll phase
database = {}

for device_id, puf in enumerate(pufs):
    c = generate_challenge()
    r = get_response(puf, c)
    database[device_id] = (c, r)

# Verify phase
def authenticate(device_id, puf, noise=0.1):
    c, stored_r = database[device_id]
    new_r = get_response(puf, c, noise)
    return stored_r == new_r

print("Authentication Test:")
for i in range(5):
    print(f"Device {i}:", authenticate(i, pufs[i]))
